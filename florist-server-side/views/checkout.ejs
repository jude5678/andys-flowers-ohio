                    function ShoppingApp() {
                            const [products] = useState(window.PRODUCT_DATA || []);
                            const [isCartVisible, setIsCartVisible] = useState(false);
                            
                            const [cartItems, setCartItems] = useState(() => {
                                const savedCart = sessionStorage.getItem('userCart');
                                return savedCart ? JSON.parse(savedCart) : [];
                            });

                             // DEBUG: Log every render
                            console.log('🔄 ShoppingApp re-rendering');
                            console.log('Cart items length:', cartItems.length);
                            console.log('Is cart visible:', isCartVisible);

                            useEffect(() => {
                                sessionStorage.setItem('userCart', JSON.stringify(cartItems));
                                console.log('💾 Cart saved to sessionStorage, this triggers re-render');
                            }, [cartItems]);
                                                                
                            // useEffect(() => {
                            //     sessionStorage.setItem('userCart', JSON.stringify(cartItems));
                            // }, [cartItems])

                        
                    
                            const subtotal = cartItems.reduce((sum, item) => sum + (item.price * item.quantity), 0);
                            const total = cartItems.reduce((sum, item) => sum + (item.price * item.quantity), 15);
                    
                            const handleAddClick = (e, product) => {
                                e.preventDefault();
                                const numericPrice = parseFloat(product.formattedPrice.replace(/[^0-9.]/g, ''));
                                const thumbnail = product.images[0]?.url;
                                
                                if (!isNaN(numericPrice)) {
                                    setCartItems(prevItems => {
                                        const existingItem = prevItems.find(item => item.name === product.title);
                                        if (existingItem) {
                                            return prevItems.map(item =>
                                                item.name === product.title 
                                                    ? { ...item, quantity: item.quantity + 1 } 
                                                    : item
                                            );
                                        }
                                        return [...prevItems, {  thumbnail: thumbnail, name: product.title, price: numericPrice, quantity: 1 }];
                                    });
                                }
                            };
                    
                            const handleRemoveClick = (indexToRemove) => {
                                setCartItems(prevItems => 
                                    prevItems.filter((_, index) => index !== indexToRemove)
                                );
                            };
                    
                            const updateQuantity = (index, delta) => {
                                setCartItems(prevItems => prevItems.map((item, i) => {
                                    if (i === index) {
                                        const newQty = Math.max(1, item.quantity + delta);
                                        return { ...item, quantity: newQty };
                                    }
                                    return item;
                                }))
                            };

                            // get customer's shipping info
                            sdk.store.cart.update(cart.id, {
                                email: "customer@example.com",
                                region_id: "region_123",
                                shipping_address: {
                                    first_name: "John",
                                    last_name: "Doe",
                                    address_1: "123 Main St",
                                    city: "New York",
                                    postal_code: "10001",
                                    country_code: "us",
                                    province: "us-ny",
                                    phone: "1234567890",
                                }
                            })
                            .then(({ cart: updatedCart }) => {
                                console.log(updatedCart)
                            })

                            // retrieve available shipping options
                            sdk.store.fulfillment.listCartOptions({
                                cart_id: cart.id,
                            })
                            .then(({ shipping_options }) => {
                                console.log(shipping_options) // show these to the customer
                            })

                            // once chosen by customer, add it to cart
                            sdk.store.cart.addShippingMethod(cart.id, {
                                option_id: "so_123", // ID of the chosen shipping option
                            })
                            .then(({ cart: updatedCart }) => {
                                console.log(updatedCart)
                            })

                            // determine status of cart completion
