                                if (data.type === "cart" && data.cart) {
                                    // an error occurred
                                    console.error(data.error)
                                } else if (data.type === "order" && data.order) {
                                    // Order placed successfully
                                    localStorage.removeItem("cart_id")
                                    console.log(data.order)
                                }
                            })

