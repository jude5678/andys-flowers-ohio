                                                        </label>

                                                    </div>

                                                    <div className="lineThree">

                                                        <label htmlFor="deliveryInstructions"> Delivery Instructions *
                                                            <textarea name="deliveryInstructions" id="deliveryInstructions" rows="4" required
                                                            placeholder="Please sepcify any additional delivery details here, we aim to deliver all orders between 10am-4pm.">
                                                            </textarea>
                                                        </label>

                                                    </div>
                                                </form>
                                            </div>
                                        
                                            <div className="giftMessage">
