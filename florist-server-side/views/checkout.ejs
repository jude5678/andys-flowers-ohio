                                                            </textarea>
                                                        </label>

                                                    </div>
                                                </form>
                                            </div>
                                        </div>


                                        <div className="yourOrder">
                                            <h2> Your Order</h2>
                                            <table>
                                                <tbody>
                                                    <tr>
                                                        <td>Product</td>
                                                        <td>Subtotal</td>
                                                    </tr>
                                                    <tr>
                                                        <td>
                                                            
                                                            <ul className="cart-item-names">
                                                                {cartItems.map((item, index) => (
                                                                    <li key={index} style={{ fontSize: '0.8em', display: 'flex', justifyContent: 'center', marginBottom: '.3em' }}>
                                                                        <span>
                                                                            <img 
                                                                                src={item.thumbnail} 
                                                                                alt={item.name} 
                                                                                style={{ width: '40px', height: '40px', objectFit: 'contain', borderRadius: '4px' }} 
                                                                            />
                                                                            <div>
                                                                            {item.name} x{item.quantity}
                                                                            </div>
                                                                        </span>
                                                                    </li>
                                                                ))}
                                                            </ul>

                                                        </td>
                                                        <td> <p>${subtotal.toFixed(0)}</p> </td>
                                                    </tr>
                                                    <tr>
                                                        <td>Subtotal</td>
                                                        <td> ${subtotal.toFixed(0)} </td>
                                                    </tr>
                                                    <tr>
                                                        <td>Shipment</td>
                                                        <td>Enter your address to view shipping options.</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Tax</td>
                                                        <td>$15</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Total</td>
                                                        <td> ${total.toFixed(0)} </td>
                                                    </tr>
                                                
                                            

                                                </tbody>
                                            </table>

                                        </div>

                                    </div>
                                    
                                </div>
                            )
                        }

                        const root = ReactDOM.createRoot(document.getElementById('root'));
                        root.render(<ShoppingApp />);
                </script>

                <script>
                    console.log('setting up Stripe with vanilla JS');
                
                    let stripeSetupComplete = false;
                
                    function setupStripe() {
                    if (stripeSetupComplete) return;
                    
                    console.log('starting Stripe setup...');
                    
                    fetch('/create-payment-intent', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ amount: 1999, currency: 'usd' })
                    })
                    .then(res => res.json())
                    .then(data => {
                        console.log('got clientSecret');
                        
                        const stripe = Stripe('pk_test_51TIzQcDTKOEuTpmuoPJ9VwFDK3JZViceRb7zlGznAEidYNxLkOWPTupwqD1PGkHF3kUSvqVqX6jMUZMclIzB59iK0026vJFEpv');
                        const elements = stripe.elements({ clientSecret: data.clientSecret });
                        const paymentElement = elements.create('payment');
                        
                        paymentElement.mount('#stripe-payment-element');
                        console.log('Stripe mounted successfully');
                        
                        document.getElementById('stripe-form').onsubmit = async (e) => {
                        e.preventDefault();
                        
                        const submitBtn = document.getElementById('stripe-submit-btn');
                        const errorDiv = document.getElementById('stripe-error');
                        
                        submitBtn.disabled = true;
                        submitBtn.textContent = 'Processing...';
                        errorDiv.textContent = '';
                        
                        const result = await stripe.confirmPayment({
                            elements,
                            confirmParams: { return_url: window.location.origin + '/success' }
                        });
                        
                        if (result.error) {
                            errorDiv.textContent = result.error.message;
                            submitBtn.disabled = false;
                            submitBtn.textContent = 'Pay Now';
                        }
                        };
                        
                        stripeSetupComplete = true;
                    })
                    .catch(err => {
                        console.error('Stripe setup error:', err);
                        document.getElementById('stripe-error').textContent = 'Payment form failed to load';
                    });
                    }
                
                    // Run after a delay to ensure React is completely done
                    setTimeout(setupStripe, 500);
                </script>


                
            
             
             
             
            
