             <script>
 
             // converts the data to a Base64 string on the server 
             // then decodes it in the browser to prevent errors with EJS
             const encodedData = "<%= Buffer.from(JSON.stringify(products)).toString('base64') %>";
             window.PRODUCT_DATA = JSON.parse(atob(encodedData));
             
             console.log("Data successfully loaded:", window.PRODUCT_DATA);
             </script>

