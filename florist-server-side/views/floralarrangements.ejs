            <script type="text/babel">
                const { useState, useEffect } = React;
                const { createPortal } = ReactDOM;
            
                function ShoppingApp() {
                    const [products] = useState(window.PRODUCT_DATA || []);
                    const [isCartVisible, setIsCartVisible] = useState(false);
                    
                    const [cartItems, setCartItems] = useState(() => {
                        const savedCart = sessionStorage.getItem('userCart');
                        return savedCart ? JSON.parse(savedCart) : [];
                    });
                            
                    useEffect(() => {
                        sessionStorage.setItem('userCart', JSON.stringify(cartItems));
                    }, [cartItems]);
            
                    const total = cartItems.reduce((sum, item) => sum + (item.price * item.quantity), 0);
            
                    const handleAddClick = (e, product) => {
                        e.preventDefault();
                        const numericPrice = parseFloat(product.formattedPrice.replace(/[^0-9.]/g, ''));
                        const thumbnail = product.images[0]?.url
                        
                        if (!isNaN(numericPrice)) {
                            setCartItems(prevItems => {
                                const existingItem = prevItems.find(item => item.name === product.title);
                                if (existingItem) {
                                    return prevItems.map(item =>
                                        item.name === product.title 
                                            ? { ...item, quantity: item.quantity + 1 } 
                                            : item
                                    );
                                }
                                return [...prevItems, {  thumbnail: thumbnail, name: product.title, price: numericPrice, quantity: 1 }];
                            });
                        }
                    };
            
                    const handleRemoveClick = (indexToRemove) => {
                        setCartItems(prevItems => 
                            prevItems.filter((_, index) => index !== indexToRemove)
                        );
                    };
            
                    const updateQuantity = (index, delta) => {
                        setCartItems(prevItems => prevItems.map((item, i) => {
                            if (i === index) {
                                const newQty = Math.max(1, item.quantity + delta);
                                return { ...item, quantity: newQty };
                            }
                            return item;
                        }));
                    };

                    
            
                    return (
                        <div>
                            {createPortal(
                                <div className="subtotal"
                                    onPointerEnter={() => setIsCartVisible(true)}
                                    onPointerLeave={() => setIsCartVisible(false)}
                                    
                                >
                                    <p>${total.toFixed(2)}</p>
                        
                
                                    <div 
                                        className="subtotal-container"
                                      
                                    >
                
                                        {isCartVisible && (
                                            <div className="cart-dropdown">
                                                {cartItems.length === 0 ? (
                                                    <p>Your cart is empty.</p>
                                                ) : (
                                                    <ul className="cart-item-names">
                                                        {cartItems.map((item, index) => (
                                                            <li key={index} style={{ fontSize: '0.9em', display: 'flex', justifyContent: 'space-between', marginBottom: '10px' }}>
                                                                <span>
                                                                    <img 
                                                                        src={item.thumbnail} 
                                                                        alt={item.name} 
                                                                        style={{ width: '3em', height: '3em', objectFit: 'contain', borderRadius: '4px' }} 
                                                                    />
                                                                    <div>
                                                                    {item.name} - ${item.price.toFixed(2)} (x{item.quantity})
                                                                    </div>
                                                                    
                                                                </span>
                                                                <div>
                                                                    <button onClick={() => updateQuantity(index, -1)}>-</button>
                                                                    <button onClick={() => updateQuantity(index, 1)}>+</button>
                                                                    <button 
                                                                        onClick={() => handleRemoveClick(index)}
                                                                        style={{ marginLeft: '10px', color: 'red', cursor: 'pointer', border: 'none', background: 'none' }}
                                                                    >
                                                                        [Remove]
                                                                    </button>
                                                                </div>
                                                            </li>
                                                        ))}
                                                     
                                                    </ul>
                                                )}
                                                <div className="checkoutButton">
                                                            
                                                    <a className="checkout" href="/checkout">
                                                    Checkout
                                                    </a>
                                                    
                                                </div>
                                                        
                                               
                                            </div>
                                        )}
                                    </div> 
                                </div>,
                                document.getElementById('banner-two')
                            )}
                            <ul className="products">
                                {products.map((product, i) => ( 
                                    <li key={i} className="product-container" style={{ listStyle: 'none', marginBottom: '20px' }}>
                                        <img src={product.images[0]?.url} alt={product.title} style={{ width: '25em' }} />
                                        <h3>{product.title}</h3>
                                        <p>{product.formattedPrice}</p>
                                        <div 
                                            className="add-to-cart"
                                            onClick={(e) => handleAddClick(e, product)}
                                        >

                                            <button
                                            >
                                                Add to cart
                                            </button>
                                            
                                        </div>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    );
                }
            
                const root = ReactDOM.createRoot(document.getElementById('root'));
                root.render(<ShoppingApp />);
            </script>
            
             
             
             

